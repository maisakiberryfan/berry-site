# ==========================================
# MariaDB Configuration
# ==========================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=mbdb

# ==========================================
# Parquet Export Output Directory
# ==========================================
OUTPUT_DIR=/path/to/output

# ==========================================
# GitHub API Multi-file Commit
# ==========================================
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=maisakiberryfan
GITHUB_REPO=sqlBackUp
GITHUB_BRANCH=main

# ==========================================
# Discord Notification
# ==========================================
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx/xxxxx

# ==========================================
# Node Path
# ==========================================
NODE_BIN=/usr/bin/node

# ==========================================
# Cloudflare R2
# ==========================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=berry-sqldata
R2_PUBLIC_URL=https://sqldata.m-b.win
