# Berry Site - Environment Variables
# Copy this file to .env and fill in your values

# --- Database (MariaDB/MySQL) ---
DB_HOST=your-db-host.example.com
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# --- YouTube Data API v3 ---
YOUTUBEAPIKEY=your_youtube_api_key

# --- Anthropic API Key (for AI Text-to-SQL, optional) ---
ANTHROPIC_API_KEY=your_anthropic_api_key

# --- Discord Webhook URL (for notifications, optional) ---
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# --- Lambda Matcher URL (fuzzy matching service) ---
LAMBDA_MATCHER_URL=https://your-lambda-url.execute-api.region.amazonaws.com/Prod/match-setlist

# --- PubSubHubbub Callback URL ---
PUBSUB_CALLBACK_URL=https://your-domain.com/webhook/youtube

# --- GitHub Repo (for commit display, optional) ---
# GITHUB_REPO=your-org/your-repo

# --- YouTube Channel IDs (optional, has defaults) ---
# TARGET_CHANNELS=UCxxxxxxx,UCyyyyyyy
# MEMBERSHIP_PLAYLIST_ID=UUxxxxxxx

# --- Mode ---
MODE=prod
